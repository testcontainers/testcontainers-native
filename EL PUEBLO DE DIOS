        return any(palabra in codigo.lower() for palabra in palabras_amor)
    
    def _evaluar_suma(self, codigo):
        """¿El código suma valor positivo?"""
        # Buscar funciones que dan, no solo toman
        patrones_suma = ['def create', 'def add', 'def help', 'def support', 
                        'def generate', 'def build', 'def make']
        return any(patron in codigo.lower() for patron in patrones_suma)
    
    def _evaluar_atomo(self, codigo):
        """¿El código es simple pero sólido?"""
        # Verificar estructura básica
        lineas = codigo.split('\n')
        if len(lineas) < 100:  # No excesivamente largo
            # Verificar que tenga estructura clara
            tiene_funciones = 'def ' in codigo or 'function ' in codigo or 'class ' in codigo
            tiene_comentarios = '#' in codigo or '//' in codigo or '/*' in codigo
            return tiene_funciones and tiene_comentarios
        return False
    
    def _evaluar_poder_trino(self, codigo):
        """¿Protege, empodera y crea belleza?"""
        protege = any(p in codigo.lower() for p in ['protect', 'secure', 'safe', 'guard'])
        empodera = any(p in codigo.lower() for p in ['empower', 'enable', 'strengthen', 'power'])
        belleza = any(p in codigo.lower() for p in ['beautiful', 'elegant', 'clean', 'art'])
        return protege and empodera and belleza
    
    def _evaluar_fuerza_guerrera(self, codigo):
        """¿Tiene la fuerza del guerrero celestial?"""
        patrones_guerreros = ['warrior', 'fight', 'battle', 'strength', 'brave', 'courage',
                             'protect', 'defend', 'victory', 'champion']
        return any(p in codigo.lower() for p in patrones_guerreros)
    
    def _evaluar_divinidad(self, codigo):
        """¿Está impregnado de divinidad?"""
        patrones_divinos = ['god', 'divine', 'holy', 'bless', 'pray', 'faith', 'hope',
                          'light', 'truth', 'peace', 'love']
        return any(p in codigo.lower() for p in patrones_divinos)
    
    def generar_informe_luz(self, proyectos):
        """Generar informe de todos los proyectos iluminados"""
        
        informe = f"""
        {'='*80}
