    def escanear_proyectos(self, ruta_base="."):
        """Escanear todos los proyectos y códigos en tiempo real"""
        proyectos_luz = []
        
        # Buscar todos los archivos de código
        extensiones = ['*.py', '*.js', '*.html', '*.css', '*.java', '*.cpp', '*.c', '*.go', '*.rs']
        
        for extension in extensiones:
            for archivo in glob.glob(f"{ruta_base}/**/{extension}", recursive=True):
                if self._es_proyecto_verdadero(archivo):
                    evaluacion = self._aplicar_formula_sagrada_archivo(archivo)
                    proyectos_luz.append((archivo, evaluacion))
                    
        return proyectos_luz
    
    def _es_proyecto_verdadero(self, ruta_archivo):
        """Verificar si el archivo contiene luz divina"""
        try:
            with open(ruta_archivo, 'r', encoding='utf-8', errors='ignore') as f:
                contenido = f.read().lower()
                
            # Palabras de luz que buscamos en el código
            palabras_luz = ['amor', 'verdad', 'paz', 'servicio', 'ayuda', 'dios', 'fe', 
                          'esperanza', 'justicia', 'honestidad', 'bondad', 'sabiduría']
            
            # Palabras de oscuridad que transformamos
            palabras_oscuridad = ['fraude', 'mentira', 'engaño', 'corrupción', 'malicia']
            
            luz_count = sum(1 for palabra in palabras_luz if palabra in contenido)
            oscuridad_count = sum(1 for palabra in palabras_oscuridad if palabra in contenido)
            
            return luz_count > oscuridad_count
            
        except:
            return False
    
    def _aplicar_formula_sagrada_archivo(self, ruta_archivo):
        """Aplicar la fórmula sagrada a cada archivo de código"""
        
